# Treningsanalyse Backend Environment Variables
# Kopier denne filen til .env og fyll inn dine verdier

# Database Configuration
# Anbefalt: la DATABASE_URL stå tom for å bruke prosjektets standard (backend/data/treningsanalyse.db).
# Hvis du overstyrer, bruk absolutt sti for portabilitet, f.eks.:
# DATABASE_URL=sqlite:////absolutt/sti/til/backend/data/treningsanalyse.db
# DATABASE_URL=

# Garmin Connect Credentials
# PÅKREVD: Dine Garmin Connect innloggingsdetaljer
GARMIN_EMAIL=din.epost@example.com
GARMIN_PASSWORD=ditt_passord_her

# Token Storage Directory
# Valgfritt. Hvis tom/utelatt brukes standard token-mappe under backend.
# Anbefalt: bruk absolutt sti ved overstyring.
# TOKEN_DIR=

# Data Storage Directory
# Valgfritt. Hvis tom/utelatt brukes standard backend/data.
# Anbefalt: bruk absolutt sti ved overstyring.
# DATA_DIR=

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Redis (valgfritt — raskere cache; uten Redis brukes in-memory)
# Start lokalt: docker run -d --name treningsanalyse-redis -p 6379:6379 redis:7-alpine
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# Vær på aktiviteter
# MET User-Agent (påkrevd av api.met.no) — locationforecast dekker kun fremtid
MET_API_USER_AGENT=Treningsanalyse/1.0 (din@epost.example)

# Frost API for historisk temperatur/vind (anbefalt for norske økter)
# https://frost.met.no/auth/requestCredentials.html
# Uten FROST lagres temperatur fra Garmin (min/max på activitylist), ikke vind fra API.
FROST_CLIENT_ID=

# Optional: Lactate Threshold Speed (m/s)
# LACTATE_THRESHOLD_SPEED=3.1056












